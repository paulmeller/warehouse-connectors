{
  "version": 1,
  "name": "notion",
  "description": "Notion pages and databases.",
  "api_type": "rest",
  "governance_fields": ["title", "url"],
  "auth": {
    "type": "config_key",
    "key": "notion.api_key",
    "header_name": "Authorization",
    "header_prefix": "Bearer"
  },
  "client": {
    "default_headers": {
      "Notion-Version": "2022-06-28",
      "Content-Type": "application/json"
    }
  },
  "tables": [
    {
      "name": "notion_pages",
      "columns": [
        { "name": "id", "type": "TEXT", "primary_key": true },
        { "name": "url", "type": "TEXT" },
        { "name": "title", "type": "TEXT" },
        { "name": "created_time", "type": "TEXT" },
        { "name": "last_edited_time", "type": "TEXT" },
        { "name": "parent_type", "type": "TEXT" },
        { "name": "parent_id", "type": "TEXT" },
        { "name": "archived", "type": "INTEGER" },
        { "name": "_extracted_at", "type": "TIMESTAMP", "default": "CURRENT_TIMESTAMP" }
      ],
      "endpoint": {
        "url": "https://api.notion.com/v1/search",
        "method": "POST",
        "body": {
          "filter": { "value": "page", "property": "object" },
          "sort": { "timestamp": "last_edited_time", "direction": "descending" },
          "page_size": 100
        },
        "pagination": {
          "type": "cursor",
          "page_size": 100,
          "max_pages": 50,
          "cursor_path": "next_cursor",
          "has_next_path": "has_more",
          "cursor_variable": "start_cursor"
        },
        "rate_limit": { "delay_seconds": 0.4 },
        "incremental": {
          "stop_date_path": "last_edited_time"
        }
      },
      "response": {
        "results_path": "results",
        "field_mappings": [
          { "column": "id", "path": "id" },
          { "column": "url", "path": "url" },
          {
            "column": "title",
            "path": "properties.Name.title[0].plain_text",
            "alt_paths": [
              "properties.Title.title[0].plain_text",
              "properties.title.title[0].plain_text",
              "properties.Page.title[0].plain_text"
            ]
          },
          { "column": "created_time", "path": "created_time" },
          { "column": "last_edited_time", "path": "last_edited_time" },
          { "column": "parent_type", "path": "parent.type" },
          {
            "column": "parent_id",
            "path": "parent.database_id",
            "alt_paths": [
              "parent.page_id",
              "parent.workspace"
            ]
          },
          { "column": "archived", "path": "archived", "transform": "to_bool" }
        ]
      }
    },
    {
      "name": "notion_databases",
      "columns": [
        { "name": "id", "type": "TEXT", "primary_key": true },
        { "name": "url", "type": "TEXT" },
        { "name": "title", "type": "TEXT" },
        { "name": "description", "type": "TEXT" },
        { "name": "created_time", "type": "TEXT" },
        { "name": "last_edited_time", "type": "TEXT" },
        { "name": "archived", "type": "INTEGER" },
        { "name": "_extracted_at", "type": "TIMESTAMP", "default": "CURRENT_TIMESTAMP" }
      ],
      "endpoint": {
        "url": "https://api.notion.com/v1/search",
        "method": "POST",
        "body": {
          "filter": { "value": "database", "property": "object" },
          "sort": { "timestamp": "last_edited_time", "direction": "descending" },
          "page_size": 100
        },
        "pagination": {
          "type": "cursor",
          "page_size": 100,
          "max_pages": 50,
          "cursor_path": "next_cursor",
          "has_next_path": "has_more",
          "cursor_variable": "start_cursor"
        },
        "rate_limit": { "delay_seconds": 0.4 },
        "incremental": {
          "stop_date_path": "last_edited_time"
        }
      },
      "response": {
        "results_path": "results",
        "field_mappings": [
          { "column": "id", "path": "id" },
          { "column": "url", "path": "url" },
          { "column": "title", "path": "title[0].plain_text" },
          { "column": "description", "path": "description[0].plain_text" },
          { "column": "created_time", "path": "created_time" },
          { "column": "last_edited_time", "path": "last_edited_time" },
          { "column": "archived", "path": "archived", "transform": "to_bool" }
        ]
      }
    }
  ],
  "fts": [
    {
      "table_name": "notion_fts",
      "source_table": "notion_pages",
      "columns": ["title"],
      "tokenizer": "porter unicode61",
      "id_column": "id",
      "map_id_column": "notion_id",
      "source_tag": "pages",
      "search_type": "notion",
      "title_column": "title",
      "date_column": "last_edited_time",
      "snippet_column": 0,
      "metadata_columns": {
        "url": "t.url",
        "date": "t.last_edited_time",
        "kind": "'page'"
      }
    },
    {
      "table_name": "notion_fts",
      "source_table": "notion_databases",
      "columns": ["title"],
      "tokenizer": "porter unicode61",
      "id_column": "id",
      "map_id_column": "notion_id",
      "source_tag": "databases",
      "search_type": "notion",
      "title_column": "title",
      "date_column": "last_edited_time",
      "snippet_column": 0,
      "metadata_columns": {
        "url": "t.url",
        "date": "t.last_edited_time",
        "kind": "'database'"
      }
    }
  ]
}
